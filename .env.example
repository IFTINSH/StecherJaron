# Sanity — von sanity.io/manage (oder `npx sanity init`)
# Kopiere diese Datei nach .env.local und trage die echte Project-ID ein.
# Dieselben Werte auch bei Netlify unter Site configuration → Environment variables setzen.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
